{
  "name": "n-tier-banking",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "dotenvx run -- nest start",
    "start:dev": "dotenvx run -- nest start --watch",
    "start:prod": "dotenvx run -- node dist/src/main.js",
    "test": "vitest run && vitest run --config vitest.integration.config.mts",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.mts",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "format": "biome format --write src/ test/"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.61.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "drizzle-orm": "^0.39.0",
    "helmet": "^8.1.0",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.3.0",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/core": "^1.10.0",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "typescript": "^5.7.0",
    "unplugin-swc": "^1.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22 <23"
  }
}
